{
  "name": "@wexample/js-helpers",
  "version": "0.0.36",
  "description": "Modern, type-safe helper utilities for Wexample projects.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "lint": "npm run typecheck",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "wexample",
    "helpers",
    "utility",
    "kebab-case"
  ],
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "repository": "https://github.com/wexample/js-helpers",
  "files": [
    "src"
  ],
  "exports": {
    "./*": {
      "types": "./src/*.ts",
      "default": "./src/*.ts"
    }
  },
  "typesVersions": {
    "*": {
      "*": [
        "src/*"
      ]
    }
  }
}